    "version": "0.2.0",
    "configurations": [
        {
            "name": "Current File - Run Console",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "APP_DEBUG": "0"
            },
        },
        {
            "name": "Current File - Debug Console",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "internalConsole",
            "justMyCode": true,
            "env": {
                "APP_DEBUG": "true"
            }
        },
    ]
}